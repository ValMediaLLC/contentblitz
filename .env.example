# Environment variable configuration for ContentBlitz
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SERP_API_KEY=
PERPLEXITY_API_KEY=
LANGSMITH_API_KEY=
STABILITY_API_KEY=
FAL_AI_API_KEY=

# Optional live-test flags (0 = disabled, 1 = enabled)
CONTENTBLITZ_RUN_LIVE_TESTS=0
CONTENTBLITZ_RUN_LIVE_IMAGE_TESTS=0

# Runtime control (0 = disabled, 1 = enabled)
# Master switch for provider API calls across tools.
CONTENTBLITZ_ENABLE_LIVE_CALLS=0

# Optional image provider registry overrides
# Selection via env/config (primary + fallback chain for generate_image).
CONTENTBLITZ_IMAGE_PROVIDER=stability_ai
CONTENTBLITZ_IMAGE_PROVIDER_FALLBACK=fal_ai
CONTENTBLITZ_IMAGE_MODEL_PRIMARY=stable-image-core
CONTENTBLITZ_IMAGE_MODEL_FALLBACK=fal-ai/fast-sdxl

# Optional cache backend configuration
# If unset, ContentBlitz uses in-memory cache by default.
CONTENTBLITZ_CACHE_BACKEND=sqlite
CONTENTBLITZ_CACHE_TTL_SECONDS=1800
CONTENTBLITZ_CACHE_SQLITE_PATH=.tmp/contentblitz_cache.sqlite3

# LangSmith tracing configuration
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="ContentBlitz"
CONTENTBLITZ_TRACE_SAMPLE_RATE=1.0
CONTENTBLITZ_TRACE_FAILURE_SAMPLE_RATE=1.0
CONTENTBLITZ_RUN_LANGSMITH_SMOKE=0

# Optional text model policy overrides
# Global defaults used when an agent-specific override is not provided.
# CONTENTBLITZ_TEXT_PROVIDER=openai
# CONTENTBLITZ_TEXT_MODEL_DEFAULT=gpt-4o
# CONTENTBLITZ_TEXT_MODEL_FALLBACK=gpt-4o-mini
# CONTENTBLITZ_DEFAULT_TEXT_MODEL=gpt-4o
# CONTENTBLITZ_ENABLE_ANTHROPIC_PROMPT_CACHE=0

# Recommended recent OpenAI text model IDs (examples)
# CONTENTBLITZ_TEXT_MODEL_DEFAULT=gpt-5.4
# CONTENTBLITZ_TEXT_MODEL_FALLBACK=gpt-5.4-mini
#
# Recommended Anthropic Claude model IDs (examples; verify current availability)
# CONTENTBLITZ_TEXT_PROVIDER=anthropic
# CONTENTBLITZ_DEFAULT_TEXT_MODEL=claude-3-5-sonnet-latest
# CONTENTBLITZ_TEXT_MODEL_FALLBACK=claude-3-5-haiku-latest
# CONTENTBLITZ_ENABLE_ANTHROPIC_PROMPT_CACHE=1
#
# Alternate compatible OpenAI IDs:
# - gpt-5.5
# - gpt-5.4
# - gpt-5.4-mini
# - gpt-4.1
# - gpt-4.1-mini
# - gpt-4o-mini
#
# Alternate compatible Anthropic IDs:
# - claude-3-7-sonnet-latest
# - claude-3-5-sonnet-latest
# - claude-3-5-haiku-latest
# - claude-3-opus-latest
#
# Example per-agent overrides
# CONTENTBLITZ_TEXT_MODEL_QUERY_HANDLER_DEFAULT=gpt-5.4-mini
# CONTENTBLITZ_TEXT_MODEL_QUERY_HANDLER_FALLBACK=gpt-4.1-mini
# CONTENTBLITZ_TEXT_MODEL_CONTENT_STRATEGIST_DEFAULT=gpt-5.4-mini
# CONTENTBLITZ_TEXT_MODEL_CONTENT_STRATEGIST_FALLBACK=gpt-4.1-mini
# CONTENTBLITZ_TEXT_MODEL_BLOG_WRITER_DEFAULT=gpt-5.4
# CONTENTBLITZ_TEXT_MODEL_BLOG_WRITER_FALLBACK=gpt-5.4-mini
# CONTENTBLITZ_TEXT_MODEL_LINKEDIN_WRITER_DEFAULT=gpt-5.4-mini
# CONTENTBLITZ_TEXT_MODEL_LINKEDIN_WRITER_FALLBACK=gpt-4.1-mini
# CONTENTBLITZ_TEXT_MODEL_RESEARCH_AGENT_DEFAULT=gpt-5.4
# CONTENTBLITZ_TEXT_MODEL_RESEARCH_AGENT_FALLBACK=gpt-5.4-mini
#
# Optional structured provider/model policy by agent key (JSON)
# CONTENTBLITZ_AGENT_MODEL_POLICY={"query_handler":{"provider":"openai","model":"gpt-4.1-mini"},"content_strategist":{"provider":"anthropic","model":"claude-3-5-sonnet-latest","fallback_provider":"openai","fallback_model":"gpt-4.1-mini"}}
